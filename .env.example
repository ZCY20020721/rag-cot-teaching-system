# 复制此文件为 .env 并填入你的 API Key

# DeepSeek 大模型 API（出题 + 批改）
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Embedding API（向量化 PDF 文本）
# 推荐智谱 AI：base_url=https://open.bigmodel.cn/api/paas/v4/  model=embedding-3
# 推荐硅基流动：base_url=https://api.siliconflow.cn/v1/  model=BAAI/bge-large-zh-v1.5
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
EMBEDDING_MODEL=embedding-3

# 若不想用云端 Embedding，可注释掉上面三行，系统会自动回退到本地 HuggingFace 模型
